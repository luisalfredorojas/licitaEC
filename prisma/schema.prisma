// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────

enum SubscriptionPlan {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ProcurementStatus {
  PLANNING
  TENDER
  AWARD
  CONTRACT
  CANCELLED
}

enum AlertType {
  NEW_PROCESS
  DEADLINE_REMINDER
  STATUS_CHANGE
  AWARDED
}

enum TrackingStatus {
  INTERESTED
  PREPARING
  SUBMITTED
  WON
  LOST
  DISCARDED
}

/// Tipo específico de procedimiento ecuatoriano (SERCOP)
enum ProcurementMethod {
  SUBASTA_INVERSA         // Subasta Inversa Electrónica (SIE) — bienes normalizados
  LICITACION              // Licitación — alta cuantía
  COTIZACION              // Cotización — no normalizado cuantía media
  MENOR_CUANTIA           // Menor Cuantía — proveedores locales/micro
  INFIMA_CUANTIA          // Ínfima Cuantía — contratación directa, solo histórico
  CONSULTORIA_LISTA_CORTA // Consultoría Lista Corta — pre-calificación
  CATALOGO_ELECTRONICO    // Catálogo Electrónico
  OTHER
}

/// Clasificación OCP de competitividad del proceso
enum OcpMethodType {
  OPEN       // Alta competencia: SIE, Licitación, Cotización
  SELECTIVE  // Acceso limitado: Menor Cuantía
  LIMITED    // Pre-calificación: Consultoría Lista Corta
  DIRECT     // Contratación directa: Ínfima Cuantía (solo histórico, sin alertas)
}

// ─────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────

model Organization {
  id                     String            @id @default(cuid())
  name                   String
  ruc                    String            @unique @db.VarChar(13)
  rupCode                String?
  plan                   SubscriptionPlan  @default(BASIC)
  stripeCustomerId       String?           @unique
  stripeSubscriptionId   String?           @unique
  subscriptionStatus     String?           // active, trialing, past_due, canceled
  trialEndsAt            DateTime?
  notificationSettings   Json?             // NotificationPreferences
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  users             User[]
  cpcCodes          OrgCpcCode[]
  alerts            Alert[]
  tracking          ProcessTracking[]
  documents         BidDocument[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  orgId         String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  role          UserRole  @default(MEMBER)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  organization      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts          Account[]
  sessions          Session[]
  tracking          ProcessTracking[]   @relation("AssignedTo")
  pushSubscriptions PushSubscription[]
}

model OrgCpcCode {
  id             String   @id @default(cuid())
  orgId          String
  cpcCode        String   @db.VarChar(10)
  cpcDescription String?
  addedAt        DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, cpcCode])
}

model ProcurementProcess {
  id               String            @id @default(cuid())
  ocid             String            @unique
  title            String
  description      String?           @db.Text
  buyerName        String
  buyerId          String?
  buyerProvince    String?
  buyerCanton      String?
  status           ProcurementStatus @default(PLANNING)
  procurementMethod ProcurementMethod @default(OTHER)
  ocpMethodType    OcpMethodType     @default(OPEN)
  isNormalizedGood Boolean?
  amountEstimated  Decimal?          @db.Decimal(15, 2)
  amountAwarded    Decimal?          @db.Decimal(15, 2)
  currency         String            @default("USD")
  publishedDate    DateTime?
  tenderEndDate    DateTime?
  awardDate        DateTime?
  cpcCodes         String[]
  winnerName       String?
  winnerId         String?
  rawOcds          Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  alerts    Alert[]
  tracking  ProcessTracking[]
  documents BidDocument[]
}

model Alert {
  id              String    @id @default(cuid())
  orgId           String
  processId       String
  matchedCpcCode  String?
  alertType       AlertType
  isRead          Boolean   @default(false)
  notifiedViaEmail Boolean  @default(false)
  notifiedAt      DateTime?
  createdAt       DateTime  @default(now())

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  process      ProcurementProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model ProcessTracking {
  id             String         @id @default(cuid())
  orgId          String
  processId      String
  internalStatus TrackingStatus @default(INTERESTED)
  assignedToId   String?
  notes          String?        @db.Text
  bidAmount      Decimal?       @db.Decimal(15, 2)
  decisionDate   DateTime?
  updatedAt      DateTime       @updatedAt

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  process      ProcurementProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  assignedTo   User?              @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@unique([orgId, processId])
}

model BidDocument {
  id           String   @id @default(cuid())
  orgId        String
  processId    String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  documentType String?
  notes        String?  @db.Text
  uploadedAt   DateTime @default(now())

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  process      ProcurementProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id                 String    @id @default(cuid())
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  releasesProcessed  Int       @default(0)
  releasesNew        Int       @default(0)
  releasesUpdated    Int       @default(0)
  errorMessage       String?   @db.Text
  status             String    @default("running") // running, success, error
}

// ─────────────────────────────────────────────────────
// NEXTAUTH MODELS
// ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
